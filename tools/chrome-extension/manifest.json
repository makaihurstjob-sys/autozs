{
  "manifest_version": 3,
  "name": "AutoZS Source Capture",
  "version": "0.2.0",
  "description": "Capture product data from supplier pages into AutoZS.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "AutoZS Capture"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": ["activeTab", "alarms", "debugger", "downloads", "scripting", "storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://www.homedepot.com/*",
    "https://www.ebay.com/*",
    "https://sell.ebay.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/autozs-logo.png", "assets/import-to-autozs.png"],
      "matches": ["https://www.homedepot.com/*", "https://www.ebay.com/*", "https://sell.ebay.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://www.homedepot.com/p/*"],
      "js": ["capture.js", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.ebay.com/*", "https://sell.ebay.com/*"],
      "js": ["ebay-dark-mode.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://www.ebay.com/*", "https://sell.ebay.com/*"],
      "js": ["capture.js", "ebay-research.js", "ebay-fill.js", "ebay-reports.js"],
      "run_at": "document_start"
    }
  ]
}
